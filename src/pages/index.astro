---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import About from "../components/About.astro";
import Testimonials from "../components/Testimonials.astro";
import Media from "../components/Media.astro";
import Contact from "../components/Contact.astro";
---

<Layout
	title="Sexoterapiaok | Santiago Ruiz Diaz - Especialista en Sexualidad y Género"
>
	<Navbar />
	<main>
		<Hero />
		<Services />
		<About />
		<Testimonials />
		<Media />
		<Contact />
	</main>
	<footer class="footer">
		<div class="container footer-grid">
			<div class="footer-brand">
				<h2>Sexoterapia<span>ok</span></h2>
				<p>
					Espacio de salud, educación y bienestar sexual desde una
					perspectiva profesional y empática.
				</p>
			</div>
			<div class="footer-links">
				<h4>Navegación</h4>
				<ul>
					<li><a href="#inicio">Inicio</a></li>
					<li><a href="#servicios">Servicios</a></li>
					<li><a href="#sobre-mi">Sobre Mí</a></li>
					<li><a href="#contacto">Contacto</a></li>
				</ul>
			</div>
			<div class="footer-newsletter">
				<h4>Recibe novedades</h4>
				<p>
					Suscríbete para recibir contenido sobre ESI y salud mental.
				</p>
				<form class="newsletter-form">
					<input type="email" placeholder="tu@email.com" required />
					<button type="submit" class="btn btn-silver btn-small"
						>Unirse</button
					>
				</form>
			</div>
		</div>
		<div class="footer-bottom">
			<p>
				&copy; 2026 Sexoterapiaok | Santiago Ruiz Diaz. Todos los
				derechos reservados.
			</p>
		</div>
	</footer>
</Layout>

<style>
	.footer {
		background: var(--primary-dark);
		color: var(--white);
		padding: 5rem 0 2rem;
		border-top: 2px solid var(--gold);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1.5fr;
		gap: 4rem;
		margin-bottom: 4rem;
	}

	.footer-brand h2 {
		color: var(--white);
		margin-bottom: 1rem;
		font-size: 1.8rem;
	}

	.footer-brand span {
		color: var(--accent);
	}

	.footer-brand p {
		opacity: 0.8;
		font-size: 1rem;
		line-height: 1.6;
	}

	h4 {
		margin-bottom: 1.5rem;
		font-size: 1.25rem;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.footer-links ul li {
		margin-bottom: 0.8rem;
	}

	.footer-links a {
		opacity: 0.7;
		font-weight: 500;
	}

	.footer-links a:hover {
		opacity: 1;
		color: var(--accent);
		padding-left: 5px;
	}

	.newsletter-form {
		display: flex;
		gap: 0.5rem;
		margin-top: 1.2rem;
	}

	.newsletter-form input {
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.2);
		color: var(--white);
		padding: 0.9rem;
		border-radius: 12px;
		flex-grow: 1;
		font-family: inherit;
	}

	.btn-small {
		padding: 0.8rem 1.5rem;
		font-size: 0.9rem;
	}

	.footer-bottom {
		text-align: center;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		opacity: 0.6;
		font-size: 0.9rem;
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}
</style>
