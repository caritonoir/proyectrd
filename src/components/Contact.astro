---

<section id="contacto" class="section contact">
  <div class="container fade-in">
    <div class="contact-wrapper glass-white">
      <div class="contact-info">
        <span class="tag">Contacto</span>
        <h2>Inicia tu proceso</h2>
        <p>
          Completa el formulario y te contactaremos para agendar tu primera
          sesión y comenzar a transformar tu bienestar sexual.
        </p>
        <div class="contact-details">
          <div class="detail-item">
            <strong>📍 Redes Sociales</strong>
            <div class="contact-social-links">
              <a
                href="https://instagram.com/sexoterapiaok"
                target="_blank"
                aria-label="Instagram"
              >
                <i class="bi bi-instagram"></i>
              </a>
              <a
                href="https://www.tiktok.com/@sexoterapiaok?_r=1&_t=ZS-954bgTW2yqw"
                target="_blank"
                aria-label="TikTok"
              >
                <i class="bi bi-tiktok"></i>
              </a>
              <a
                href="https://www.youtube.com/@sexoterapiaok"
                target="_blank"
                aria-label="Youtube"
              >
                <i class="bi bi-youtube"></i>
              </a>
              <a
                href="https://open.spotify.com/show/5BMmMKpkxAw702wiCx4SOE?si=A-cm--ULRKKoIV35-HTa4Q"
                target="_blank"
                aria-label="Spotify"
              >
                <i class="bi bi-spotify"></i>
              </a>
              <a
                href="https://www.twitch.tv/sexoterapiaok"
                target="_blank"
                aria-label="Twitch"
              >
                <i class="bi bi-twitch"></i>
              </a>
              <a
                href="https://www.linkedin.com/in/lic-santiagoruizdiaz"
                target="_blank"
                aria-label="Linkedin"
              >
                <i class="bi bi-linkedin"></i>
              </a>
            </div>
          </div>
          <div class="detail-item">
            <strong>📧 Correo Profesional</strong>
            <p>
              <a href="mailto:sexoterapia.sc@gmail.com" class="email-link"
                >sexoterapia.sc@gmail.com</a
              >
            </p>
          </div>
          <div class="detail-item">
            <strong>🖥️ Atención Online</strong>
            <p>Sesiones por Meet y Zoom</p>
          </div>
        </div>
      </div>
      <!-- Web3Forms para envío real de correos -->
      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        class="contact-form"
      >
        <!-- Reemplaza con tu propia clave de acceso de web3forms.com si es necesario -->
        <input
          type="hidden"
          name="access_key"
          value={import.meta.env.FORM_KEY}
        />
        <input
          type="hidden"
          name="subject"
          value="Nueva consulta desde la web SexoterapiaOK"
        />
        <input type="hidden" name="from_name" value="Web SexoterapiaOK" />
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display: none;"
        />

        <div class="form-group">
          <label for="name">Nombre Completo</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Tu nombre"
            required
          />
        </div>
        <div class="form-group">
          <label for="email">Correo Electrónico</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="tu@email.com"
            required
          />
          <label for="phone">Teléfono</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+54 9 11 1234 5678"
            required
          />
        </div>
        <div class="form-group">
          <label for="service">Servicio de interés</label>
          <select id="service" name="service" required>
            <option value="" disabled selected>Selecciona una opción</option>
            <option value="Psicoterapia">Psicoterapia</option>
            <option value="Sexología">Sexología</option>
            <option value="Terapia de pareja">Terapia de pareja</option>
            <option value="Talleres de ESI">Talleres de ESI</option>
            <option value="Eventos">Eventos y charlas</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Mensaje (opcional)</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Cuéntanos brevemente qué te motiva a consultar."
          ></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-block"
          >Enviar Solicitud</button
        >
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--white);
    padding-bottom: 8rem;
  }

  .glass-white {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(159, 5, 0, 0.1);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.05);
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    padding: 5rem;
    border-radius: 45px;
    border: 1px solid var(--gold);
  }

  .tag {
    color: var(--tag-color);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    display: block;
  }

  .contact-info h2 {
    font-size: 3rem;
    margin-bottom: 2rem;
    color: var(--heading-color);
  }

  .contact-info p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 3.5rem;
    line-height: 1.7;
  }

  .detail-item {
    margin-bottom: 2.5rem;
  }

  .detail-item strong {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text); /* var(--text) is white in dark mode */
    font-size: 1.1rem;
  }

  [data-theme="dark"] .detail-item strong {
    color: var(--gold); /* Gold for titles in dark mode */
  }

  .detail-item p {
    color: var(--text);
  }

  .detail-item a.email-link {
    color: var(--text);
    text-decoration: none;
    transition: var(--transition);
  }

  .detail-item a.email-link:hover {
    color: var(--primary);
    text-decoration: underline;
  }

  .contact-social-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.8rem;
  }

  .contact-social-links a {
    font-size: 1.5rem;
    color: var(--text);
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--background);
    width: 45px;
    height: 45px;
    border-radius: 50%;
    border: 1px solid var(--border);
  }

  .contact-social-links a:hover {
    background: var(--primary);
    color: #ffffff;
    transform: translateY(-3px);
    border-color: var(--primary);
  }

  [data-theme="dark"] .contact-social-links a:hover {
    background: var(--gold);
    color: #000000;
    border-color: var(--gold);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
    background: var(--white);
    padding: 3rem;
    border-radius: 30px;
    border: 1px solid var(--border);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  label {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }

  input,
  select,
  textarea {
    padding: 1.1rem;
    border-radius: 15px;
    border: 1px solid var(--border);
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
    background: var(--background);
    color: var(--text);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.2);
  }

  [data-theme="dark"] input,
  [data-theme="dark"] select,
  [data-theme="dark"] textarea {
    background: #1a1a1a;
  }

  .btn-block {
    width: 100%;
    margin-top: 1rem;
    padding: 1.3rem;
    font-size: 1.15rem;
    border-radius: 18px;
  }

  @media (max-width: 992px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.5rem;
      border-radius: 35px;
      gap: 3rem;
    }

    .contact-info h2 {
      font-size: 2.4rem;
    }

    .contact-info p {
      margin-bottom: 2.5rem;
    }

    .contact-form {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .contact-info h2 {
      font-size: 2rem;
    }

    .contact-social-links {
      flex-wrap: wrap;
    }

    .detail-item strong {
      font-size: 1rem;
    }

    input,
    select,
    textarea {
      padding: 0.9rem;
    }
  }
</style>
