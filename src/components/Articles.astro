---
import { getArticlesFromDrive } from "../lib/googleDrive";
import fs from 'node:fs';
import path from 'node:path';

// 1. Obtener credenciales (Astro las inyecta aquí durante el build)
let clientEmail, privateKey, folderId;

// Intentar localmente primero (para desarrollo)
const keyPath = path.resolve(process.cwd(), 'gdrive-key.json');
if (fs.existsSync(keyPath)) {
  const creds = JSON.parse(fs.readFileSync(keyPath, 'utf8'));
  clientEmail = creds.client_email;
  privateKey = creds.private_key;
  folderId = import.meta.env.GDRIVE_FOLDER_ID; // El ID lo seguimos sacando del env
} else {
// Producción (Netlify) con triple redundancia
  clientEmail = import.meta.env.GDRIVE_CLIENT_EMAIL || process.env.GDRIVE_CLIENT_EMAIL;
  privateKey = import.meta.env.GDRIVE_PRIVATE_KEY || process.env.GDRIVE_PRIVATE_KEY;
  folderId = import.meta.env.GDRIVE_FOLDER_ID || process.env.GDRIVE_FOLDER_ID;
}

// FORZAR ERROR SI FALTA ALGO (Para ver en los logs de Netlify)
if (!clientEmail || !privateKey || !folderId) {
  throw new Error(`ERROR DE CONSTRUCCION: Faltan variables de entorno. Email: ${!!clientEmail}, Key: ${!!privateKey}, Folder: ${!!folderId}`);
}

const allArticlesFromDrive = await getArticlesFromDrive(clientEmail, privateKey, folderId);

if (!allArticlesFromDrive || allArticlesFromDrive.length === 0) {
  // Solo lanzamos error si no es modo desarrollo
  if (import.meta.env.PROD) {
    throw new Error('ERROR DE CONSTRUCCION: No se pudieron obtener artículos de Google Drive. Revisa los permisos de la carpeta y la API.');
  }
}

// Fallback for development if Drive is empty or not connected
const fallbackArticles = [
  {
    title: "Cargando artículos...",
    category: "General",
    description: "Estamos sincronizando el contenido con Google Drive.",
    link: "#",
    date: "---",
  },
];

const allArticles =
  allArticlesFromDrive.length > 0 ? allArticlesFromDrive : fallbackArticles;
const categories = [...new Set(allArticles.map((a) => a.category))];
const GDriveFolderURL = `https://drive.google.com/drive/folders/${import.meta.env.GDRIVE_FOLDER_ID}`;
---

<section id="articulos" class="section articles">
  <div class="container fade-in">
    <div class="section-header">
      <span class="tag">Blog & Recursos</span>
      <h2>Artículos y Notas</h2>
      <p>
        Explorá nuestra biblioteca de contenidos actualizados periódicamente por
        nuestro equipo de especialistas.
      </p>
    </div>

    <div class="articles-filter">
      <a
        href={GDriveFolderURL}
        target="_blank"
        class="filter-btn all-link"
        aria-label="Ver todas las categorías en Drive"
      >
        <span>Todos</span>
        <i class="bi bi-box-arrow-up-right"></i>
      </a>
      {
        categories.map((category, index) => (
          <button
            class={`filter-btn ${index === 0 ? "active" : ""}`}
            data-category={category}
          >
            {category}
          </button>
        ))
      }
    </div>

    <div class="articles-grid" id="articles-grid">
      {
        allArticles.map((article) => (
          <article class="article-card" data-category={article.category}>
            <div class="article-content">
              <span class="article-category">{article.category}</span>
              <span class="article-date">{article.date}</span>
              <h3>{article.title}</h3>
              <p>{article.description}</p>
              <div class="card-footer">
                <a href={article.link} target="_blank" class="link">
                  Leer artículo →
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  function initFilters() {
    const filterBtns = document.querySelectorAll(".filter-btn:not(.all-link)");
    const articleCards = document.querySelectorAll(".article-card");

    if (!filterBtns.length || !articleCards.length) return;

    function applyFilter(filter) {
      let count = 0;
      articleCards.forEach((card) => {
        if (card.getAttribute("data-category") === filter && count < 4) {
          card.style.display = "flex";
          card.style.animation = "fadeIn 0.5s ease forwards";
          count++;
        } else {
          card.style.display = "none";
        }
      });
    }

    // Initialize with the first active category
    const initialFilter = document
      .querySelector(".filter-btn.active")
      ?.getAttribute("data-category");
    if (initialFilter) applyFilter(initialFilter);

    filterBtns.forEach((btn) => {
      btn.onclick = () => {
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        applyFilter(btn.getAttribute("data-category"));
      };
    });
  }

  document.addEventListener("DOMContentLoaded", initFilters);
  document.addEventListener("astro:page-load", initFilters);
</script>

<style>
  .articles {
    background: var(--white);
    position: relative;
    overflow: hidden;
  }

  .container {
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .tag {
    color: var(--tag-color);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    display: block;
  }

  h2 {
    font-size: 3rem;
    margin-bottom: 1.5rem;
    color: var(--heading-color);
  }

  .section-header p {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .articles-filter {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 0.8rem 1.8rem;
    border-radius: 50px;
    background: var(--background);
    border: 1px solid var(--border);
    color: var(--text-muted);
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }

  .filter-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .filter-btn.active {
    background: var(--primary);
    color: #ffffff;
    border-color: var(--primary);
    box-shadow: 0 4px 15px rgba(159, 5, 0, 0.2);
  }

  [data-theme="dark"] .filter-btn.active {
    background: var(--gold);
    color: #000000;
    border-color: var(--gold);
  }

  .all-link {
    background: var(--primary-dark);
    color: var(--white);
    border-color: var(--primary-dark);
  }

  .all-link:hover {
    background: var(--primary);
    color: var(--white);
    border-color: var(--primary);
  }

  [data-theme="dark"] .all-link {
    background: #1a1a1a;
    color: var(--gold);
    border-color: var(--gold);
  }

  [data-theme="dark"] .all-link:hover {
    background: var(--gold);
    color: #000000;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
  }

  .article-card {
    background: var(--background);
    border-radius: 30px;
    padding: 2.5rem 2rem;
    border: 1px solid var(--border);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.02);
  }

  .article-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow);
    border-color: var(--gold);
    background: var(--white);
  }

  [data-theme="dark"] .article-card {
    background: #121212;
  }

  [data-theme="dark"] .article-card:hover {
    border-color: var(--gold);
    background: #1a1a1a;
  }

  .article-category {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 0.5rem;
  }

  [data-theme="dark"] .article-category {
    color: var(--gold);
  }

  .article-date {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1.5rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-bottom: 1.2rem;
    line-height: 1.3;
    color: var(--text);
  }

  .article-card p {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    justify-content: flex-end;
  }

  .link {
    color: var(--primary);
    font-weight: 700;
    font-size: 0.95rem;
    transition: var(--transition);
  }

  [data-theme="dark"] .link {
    color: var(--gold);
  }

  .link:hover {
    text-decoration: underline;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }

    .articles-filter {
      gap: 0.6rem;
    }

    .filter-btn {
      padding: 0.6rem 1.2rem;
      font-size: 0.9rem;
    }
  }
</style>
